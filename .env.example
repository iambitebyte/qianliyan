# Server port
PORT=3000

# Data folder path (relative to project root or absolute path)
DATA_DIR=./data

# Base path for nginx reverse proxy (default: /)
# Set to something like /qianliyan if using nginx reverse proxy with a prefix
# Example: BASE_PATH=/qianliyan
# Leave as / for normal deployment without prefix
BASE_PATH=/
NEXT_PUBLIC_BASE_PATH=/

# Authentication (change these for production)
AUTH_USERNAME=root
AUTH_PASSWORD=qianliyan
